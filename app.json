{
  "name": "Telegram AI Coding Assistant Bot",
  "description": "Advanced Telegram bot with AI coding assistance, file analysis, and document processing",
  "repository": "https://github.com/yourusername/telegram-ai-coding-assistant",
  "env": {
    "API_ID": {
      "description": "Telegram API ID from my.telegram.org",
      "required": true
    },
    "API_HASH": {
      "description": "Telegram API Hash from my.telegram.org",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "Telegram Bot Token from @BotFather",
      "required": true
    },
    "MONGO_URI": {
      "description": "MongoDB connection URI (use MongoDB Atlas)",
      "required": true
    },
    "AI_API_KEYS": {
      "description": "JSON object with AI API keys",
      "required": true
    },
    "OWNER_ID": {
      "description": "Your Telegram user ID",
      "required": true
    },
    "LOG_CHANNEL_ID": {
      "description": "Channel ID for logging (optional)",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": ["mongolab:sandbox"],
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
